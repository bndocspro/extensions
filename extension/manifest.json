{
  "manifest_version": 3,
  "name": "Quiz Auto Pro",
  "version": "1.0",
  "description": "Professional Chrome Extension for automated quiz answering on chorcha.net.",
  "action": {
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "*://chorcha.net/*",
    "*://mujib.chorcha.net/*",
    "https://generativelanguage.googleapis.com/*",
    "https://cdn.jsdelivr.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://chorcha.net/*", "*://mujib.chorcha.net/*"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["*://chorcha.net/*", "*://mujib.chorcha.net/*"]
    }
  ]
}
